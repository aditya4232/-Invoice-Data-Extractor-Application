# Invoice Data Extractor Configuration
# Copy this file to .env and update values as needed

# Tesseract OCR path (required on Windows)
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS/Linux: usually auto-detected, leave empty if in PATH
TESSERACT_CMD=

# Output directories
OUTPUT_DIR=output
LOGS_DIR=logs
CACHE_DIR=cache

# Processing settings
BATCH_SIZE=10
PREPROCESS_DEFAULT=True
CONFIDENCE_THRESHOLD=50

# Supported file extensions
SUPPORTED_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.tiff,.tif,.gif,.pdf